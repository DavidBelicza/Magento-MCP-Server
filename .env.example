FRONTEND_HTTP_PORT=8080
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
GRAFANA_HTTP_PORT=3001

REDIS_URL=redis://magentic_redis:6379

POSTGRES_DB=magentic
POSTGRES_USER=magentic
POSTGRES_PASSWORD=dev-password
POSTGRES_URL=postgres://magentic:dev-password@magentic_postgres:5432/magentic

NEO4J_URI=bolt://magentic_graphdb:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=dev-password

GRAPH_BATCH_SIZE=5000

# MCP server (magentic_mcp). Allowed origins default to localhost and 127.0.0.1
# on FRONTEND_HTTP_PORT, so changing the port above is enough for the default
# setup. Override MCP_ALLOWED_ORIGINS only to serve the site from another
# host/domain (comma-separated, e.g. http://abc.test:8080). Requests without an
# Origin header (CLI/desktop agents) are always allowed; browser requests must
# match an allowed origin.
# MCP_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
# MAGENTIC_BACKEND_URL=http://magentic_backend:3000

MAGENTIC_ANALYZED_SOURCE_HOST_PATH=./www/path/to/magento/source-code
MAGENTIC_ANALYZED_SOURCE_CONTAINER_PATH=/mnt/analyzed-source
ENABLE_TELEMETRY=true
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
