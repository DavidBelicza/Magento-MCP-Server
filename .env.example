# Absolute path to the root of Magento source code on your local machine.
# After chaning, restart with with `docker-compose up -d`
MAGENTIC_ANALYZED_SOURCE_HOST_PATH=./www/path/to/magento/source-code

# Only change the port if it is conflicting with other services on your machine.
# After chaning, restart with with `docker-compose up -d`
FRONTEND_HTTP_PORT=8081

# Change this to any string here for securty reasons.
# After that recreate the containers with `docker-compose up -d` to apply the changes on server side.
# Apply the same token to the frontend on localhost.
# Reload the MCP config with the new token to you AI Agent.
# MAGENTIC_API_TOKEN=example-token

# Only change the port if it is conflicting with other services on your machine.
# GRAFANA_HTTP_PORT=3001

# Enable, if you want to alter the features, and debug your changes.
# ENABLE_TELEMETRY=false


# GRAPH_BATCH_SIZE=5000

# NEO4J_HTTP_PORT=7474
# NEO4J_BOLT_PORT=7687
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=dev-password

# POSTGRES_DB=magentic
# POSTGRES_USER=magentic
# POSTGRES_PASSWORD=dev-password

# Vector database (pgvector) for semantic config search; shares the Postgres credentials above.
# POSTGRES_VECTOR_DB=magentic_vectors

# Embedding model for semantic config search (OpenAI-format /v1/embeddings endpoint).
# The bundled magentic_embedder service is always on; EMBEDDER_TYPE picks which
# embedder is used. "local" uses the in-cluster model (default, no external setup);
# "remote" uses an external server — the defaults below target LM Studio on the host.
# Switching type requires a vector reset-and-reindex.
# EMBEDDER_TYPE=local

# Local embedder (bundled embeddinggemma-300m, 768 dims, baked into the image).
# LOCAL_EMBEDDER_URL=http://magentic_embedder:8080/v1/embeddings
# LOCAL_EMBEDDER_MODEL=embeddinggemma-300m-qat
# LOCAL_EMBEDDER_BEARER_TOKEN=

# Remote embedder (defaults to LM Studio on the host).
# REMOTE_EMBEDDER_URL=http://host.docker.internal:1234/v1/embeddings
# REMOTE_EMBEDDER_MODEL=text-embedding-embeddinggemma-300m-qat
# REMOTE_EMBEDDER_BEARER_TOKEN=

# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=admin
