# Absolute path to the root of Magento source code on your local machine.
# After chaning, restart with with `docker-compose up -d`
MAGENTIC_ANALYZED_SOURCE_HOST_PATH=./www/path/to/magento/source-code

# Only change the port if it is conflicting with other services on your machine.
# After chaning, restart with with `docker-compose up -d`
FRONTEND_HTTP_PORT=8081

# Change this to any string here for securty reasons.
# After that recreate the containers with `docker-compose up -d` to apply the changes on server side.
# Apply the same token to the frontend on localhost.
# Reload the MCP config with the new token to you AI Agent.
# MAGENTIC_API_TOKEN=example-token

# Only change the port if it is conflicting with other services on your machine.
# GRAFANA_HTTP_PORT=3001

# Enable, if you want to alter the features, and debug your changes.
# ENABLE_TELEMETRY=false


# GRAPH_BATCH_SIZE=5000

# NEO4J_HTTP_PORT=7474
# NEO4J_BOLT_PORT=7687
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=dev-password

# POSTGRES_DB=magentic
# POSTGRES_USER=magentic
# POSTGRES_PASSWORD=dev-password

# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=admin
