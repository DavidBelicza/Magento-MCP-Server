{
  "name": "magentic/php-analyzer",
  "description": "PHP analysis runtime for Magentic.",
  "type": "project",
  "require": {
    "php": "^8.4",
    "nikic/php-parser": "^5.0",
    "symfony/http-foundation": "^7.2",
    "symfony/filesystem": "^7.2",
    "symfony/finder": "^7.2",
    "monolog/monolog": "^3.10",
    "phpstan/phpdoc-parser": "^2.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5",
    "phpstan/phpstan": "^2.1",
    "friendsofphp/php-cs-fixer": "^3.68"
  },
  "autoload": {
    "psr-4": {
      "Magentic\\PhpAnalyzer\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Magentic\\PhpAnalyzer\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "phpstan": "phpstan analyse",
    "cs-check": "php-cs-fixer fix --dry-run --diff",
    "cs-fix": "php-cs-fixer fix",
    "check": [
      "@cs-check",
      "@phpstan",
      "@test"
    ]
  },
  "config": {
    "allow-plugins": {
      "php-cs-fixer/shim": true
    },
    "sort-packages": true
  }
}
